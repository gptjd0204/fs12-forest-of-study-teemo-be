// Prisma 클라이언트 설정
generator client {
  provider = "prisma-client-js"
}

// 데이터베이스 연결 설정
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Study 스키마
model Study {
  id        Int      @id @default(autoincrement())
  nickname  String   
  password  String
  title     String
  description  String?
  background  String
  createdAt DateTime @default(now())  @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("studies")
}